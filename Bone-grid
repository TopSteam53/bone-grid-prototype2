<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Bone Grid - Tavern Prototype</title>
    
    <!-- Подключаем React, ReactDOM и Babel -->
    <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    
    <!-- Подключаем Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <style>
        body {
            margin: 0;
            overflow: hidden; /* Запрет скролла, как в нативном приложении */
            touch-action: none; /* Запрет зума и pull-to-refresh на мобилках */
            background-color: #0c0a09; /* stone-950 */
        }
        /* Убираем выделение текста при тапах */
        .select-none {
            -webkit-user-select: none;
            user-select: none;
        }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect } = React;

        // --- ЛОГИКА ИГРЫ ---
        const rollDie = () => Math.floor(Math.random() * 6) + 1;

        const calculateColumnScore = (column) => {
            const counts = {};
            column.forEach(val => { counts[val] = (counts[val] || 0) + 1; });
            let score = 0;
            for (let val in counts) {
                score += parseInt(val) * Math.pow(counts[val], 2);
            }
            return score;
        };

        const calculateTotalScore = (grid) => {
            return grid.reduce((total, col) => total + calculateColumnScore(col), 0);
        };

        const checkGameOver = (grid) => {
            return grid.every(col => col.length === 3);
        };

        // --- КОМПОНЕНТЫ ---
        const Die = ({ value, isOpponent }) => {
            const dots = {
                1: ['col-start-2 row-start-2'],
                2: ['col-start-1 row-start-1', 'col-start-3 row-start-3'],
                3: ['col-start-1 row-start-1', 'col-start-2 row-start-2', 'col-start-3 row-start-3'],
                4: ['col-start-1 row-start-1', 'col-start-3 row-start-1', 'col-start-1 row-start-3', 'col-start-3 row-start-3'],
                5: ['col-start-1 row-start-1', 'col-start-3 row-start-1', 'col-start-2 row-start-2', 'col-start-1 row-start-3', 'col-start-3 row-start-3'],
                6: ['col-start-1 row-start-1', 'col-start-3 row-start-1', 'col-start-1 row-start-2', 'col-start-3 row-start-2', 'col-start-1 row-start-3', 'col-start-3 row-start-3'],
            };

            if (!value) return null;

            const shadowGlow = isOpponent ? 'shadow-[0_4px_10px_rgba(159,18,57,0.3)]' : 'shadow-[0_4px_10px_rgba(180,83,9,0.3)]';

            return (
                <div className={`w-10 h-10 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl flex items-center justify-center 
                bg-gradient-to-br from-[#f8f1e5] to-[#e2d5c3] border-2 border-[#c5b49b] ${shadowGlow} transition-transform`}>
                <div className="grid grid-cols-3 grid-rows-3 gap-1 w-6 h-6 sm:w-8 sm:h-8">
                    {dots[value].map((pos, i) => (
                    <div key={i} className={`w-1.5 h-1.5 sm:w-2 sm:h-2 bg-[#4a3f35] rounded-full shadow-[inset_0_1px_2px_rgba(0,0,0,0.5)] ${pos}`}></div>
                    ))}
                </div>
                </div>
            );
        };

        const EmptySlot = () => (
            <div className="w-10 h-10 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl bg-stone-900/50 border-2 border-dashed border-stone-700/50"></div>
        );

        function App() {
            const [gameState, setGameState] = useState('menu'); 
            const [board, setBoard] = useState({ player: [[], [], []], opponent: [[], [], []] });
            const [scores, setScores] = useState({ player: 0, opponent: 0 });
            const [currentTurn, setCurrentTurn] = useState('player');
            const [currentDie, setCurrentDie] = useState(null);
            const [winner, setWinner] = useState(null);

            const startGame = () => {
                setBoard({ player: [[], [], []], opponent: [[], [], []] });
                setScores({ player: 0, opponent: 0 });
                setCurrentTurn('player');
                setCurrentDie(rollDie());
                setWinner(null);
                setGameState('playing');
            };

            const placeDie = (colIndex, turn) => {
                if (board[turn][colIndex].length >= 3) return false;
                const newBoard = { ...board };
                const otherTurn = turn === 'player' ? 'opponent' : 'player';

                newBoard[turn][colIndex] = [...newBoard[turn][colIndex], currentDie];
                newBoard[otherTurn][colIndex] = newBoard[otherTurn][colIndex].filter(val => val !== currentDie);

                setBoard(newBoard);
                const pScore = calculateTotalScore(newBoard.player);
                const oScore = calculateTotalScore(newBoard.opponent);
                setScores({ player: pScore, opponent: oScore });

                if (checkGameOver(newBoard[turn])) {
                    if (pScore > oScore) setWinner('Игрок');
                    else if (oScore > pScore) setWinner('Бот');
                    else setWinner('Ничья');
                    setGameState('gameover');
                    return true;
                }

                setCurrentTurn(otherTurn);
                setCurrentDie(rollDie());
                return true;
            };

            const handleColumnClick = (colIndex) => {
                if (currentTurn !== 'player' || gameState !== 'playing') return;
                placeDie(colIndex, 'player');
            };

            useEffect(() => {
                if (currentTurn === 'opponent' && gameState === 'playing') {
                    const botTimer = setTimeout(() => {
                        let bestCol = -1;
                        for (let i = 0; i < 3; i++) {
                            if (board.opponent[i].length < 3 && board.player[i].includes(currentDie)) { bestCol = i; break; }
                        }
                        if (bestCol === -1) {
                            for (let i = 0; i < 3; i++) {
                                if (board.opponent[i].length < 3 && board.opponent[i].includes(currentDie)) { bestCol = i; break; }
                            }
                        }
                        if (bestCol === -1) {
                            const availableCols = [0, 1, 2].filter(i => board.opponent[i].length < 3);
                            bestCol = availableCols[Math.floor(Math.random() * availableCols.length)];
                        }
                        if (bestCol !== undefined) placeDie(bestCol, 'opponent');
                    }, 800); 
                    return () => clearTimeout(botTimer);
                }
            }, [currentTurn, gameState, currentDie, board]);

            const renderColumn = (colData, isOpponent) => {
                const cells = [];
                for (let i = 0; i < 3; i++) {
                    if (i < colData.length) {
                        cells.push(<div key={i} className="flex justify-center"><Die value={colData[i]} isOpponent={isOpponent}/></div>);
                    } else {
                        cells.push(<div key={i} className="flex justify-center"><EmptySlot /></div>);
                    }
                }
                return isOpponent ? cells.reverse() : cells;
            };

            if (gameState === 'menu') {
                return (
                <div className="h-screen bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-stone-800 via-stone-950 to-stone-950 flex flex-col items-center justify-center p-4 font-serif text-stone-200 overflow-hidden">
                    <div className="max-w-sm w-full bg-stone-900/80 backdrop-blur-md rounded-2xl p-8 text-center shadow-2xl border border-stone-700/50 relative overflow-hidden">
                    <div className="absolute top-0 left-1/2 -translate-x-1/2 w-32 h-32 bg-amber-600/20 blur-[50px] rounded-full pointer-events-none"></div>
                    
                    <div className="w-20 h-20 mx-auto mb-6 flex items-center justify-center relative z-10">
                        <Die value={6} />
                    </div>
                    <h1 className="text-4xl font-black mb-3 tracking-widest text-transparent bg-clip-text bg-gradient-to-b from-amber-200 to-amber-600">BONE GRID</h1>
                    <p className="text-stone-400 mb-8 text-sm leading-relaxed font-sans">
                        Войдите в таверну. Бросайте кости, собирайте комбинации и разрушайте планы противника.
                    </p>
                    <button 
                        onClick={startGame}
                        className="w-full bg-gradient-to-b from-amber-600 to-amber-800 hover:from-amber-500 hover:to-amber-700 active:from-amber-700 active:to-amber-900 text-amber-50 font-bold py-4 rounded-xl transition-all text-lg shadow-[0_0_20px_rgba(217,119,6,0.3)] border border-amber-500/30 uppercase tracking-widest"
                    >
                        Бросить вызов
                    </button>
                    </div>
                </div>
                );
            }

            return (
                <div className="h-screen bg-stone-950 text-stone-200 font-sans flex flex-col max-w-md mx-auto relative overflow-hidden select-none">
                <div className="absolute inset-0 opacity-[0.03] pointer-events-none" style={{backgroundImage: "url('https://www.transparenttextures.com/patterns/stardust.png')"}}></div>

                {/* HEADER */}
                <div className="flex justify-between items-end px-6 py-4 bg-stone-900/90 backdrop-blur-md rounded-b-3xl border-b border-stone-800 shadow-lg shrink-0 relative z-10">
                    <div className="text-left">
                    <div className="text-[10px] text-rose-500/80 font-bold uppercase tracking-widest mb-0.5">Враг</div>
                    <div className="text-4xl font-serif text-rose-100 leading-none drop-shadow-[0_2px_10px_rgba(225,29,72,0.4)]">{scores.opponent}</div>
                    </div>
                    <div className="text-right">
                    <div className="text-[10px] text-amber-500/80 font-bold uppercase tracking-widest mb-0.5">Вы</div>
                    <div className="text-4xl font-serif text-amber-100 leading-none drop-shadow-[0_2px_10px_rgba(217,119,6,0.4)]">{scores.player}</div>
                    </div>
                </div>

                {/* ИГРОВОЕ ПОЛЕ */}
                <div className="flex-1 flex flex-col justify-between p-4 pb-6 overflow-hidden relative z-10">
                    
                    {/* Поле противника (AI) */}
                    <div className="flex justify-between space-x-3 h-1/3 min-h-0">
                    {[0, 1, 2].map(colIndex => (
                        <div key={`opp-col-${colIndex}`} className="flex-1 flex flex-col justify-end gap-2 p-2 bg-stone-900/40 rounded-2xl border border-rose-900/20 relative">
                        <div className="text-center text-rose-400/80 text-xs font-bold border-b border-rose-900/30 pb-1 mb-1 font-serif">
                            {calculateColumnScore(board.opponent[colIndex])}
                        </div>
                        <div className="flex flex-col gap-2 h-full justify-end">
                            {renderColumn(board.opponent[colIndex], true)}
                        </div>
                        </div>
                    ))}
                    </div>

                    {/* Зона броска кубика */}
                    <div className="flex flex-col items-center justify-center h-[120px] shrink-0 my-2 relative">
                    <div className="absolute inset-0 bg-amber-500/5 rounded-full blur-[40px] pointer-events-none"></div>
                    {gameState === 'playing' ? (
                        <>
                        <div className={`text-[10px] font-bold mb-3 uppercase tracking-widest transition-colors ${currentTurn === 'player' ? 'text-amber-500' : 'text-stone-500'}`}>
                            {currentTurn === 'player' ? 'Ваш бросок' : 'Ход противника'}
                        </div>
                        <div className={`transition-all duration-300 ease-out ${currentTurn === 'player' ? 'scale-125 translate-y-0' : 'scale-75 opacity-40 -translate-y-2'}`}>
                            <Die value={currentDie} isOpponent={currentTurn === 'opponent'} />
                        </div>
                        </>
                    ) : null}
                    </div>

                    {/* Поле игрока */}
                    <div className="flex justify-between space-x-3 h-1/3 min-h-0">
                    {[0, 1, 2].map(colIndex => (
                        <button 
                        key={`p-col-${colIndex}`} 
                        onClick={() => handleColumnClick(colIndex)}
                        disabled={currentTurn !== 'player' || board.player[colIndex].length >= 3 || gameState !== 'playing'}
                        className={`flex-1 flex flex-col gap-2 p-2 rounded-2xl border transition-all duration-200 relative overflow-hidden
                            ${currentTurn === 'player' && board.player[colIndex].length < 3 && gameState === 'playing'
                            ? 'bg-stone-800/80 border-amber-700/50 hover:bg-stone-800 active:scale-[0.98] cursor-pointer shadow-[0_0_15px_rgba(217,119,6,0.1)]' 
                            : 'bg-stone-900/40 border-stone-800/50 opacity-90 cursor-default'}`}
                        >
                        {currentTurn === 'player' && board.player[colIndex].length < 3 && gameState === 'playing' && (
                            <div className="absolute top-0 left-0 right-0 h-1 bg-amber-500/20"></div>
                        )}
                        <div className="flex flex-col gap-2 h-full justify-start mt-1">
                            {renderColumn(board.player[colIndex], false)}
                        </div>
                        <div className="text-center text-amber-400/80 text-xs font-bold border-t border-amber-900/30 pt-1 mt-auto font-serif">
                            {calculateColumnScore(board.player[colIndex])}
                        </div>
                        </button>
                    ))}
                    </div>
                </div>

                {/* Оверлей конца игры */}
                {gameState === 'gameover' && (
                    <div className="absolute inset-0 bg-stone-950/90 backdrop-blur-sm flex items-center justify-center z-50">
                    <div className="bg-stone-900 p-8 rounded-2xl border border-stone-700/50 text-center shadow-2xl max-w-[85%] w-full relative overflow-hidden">
                        <div className="absolute top-0 left-1/2 -translate-x-1/2 w-40 h-40 bg-amber-600/10 blur-[60px] rounded-full pointer-events-none"></div>
                        <div className="text-5xl mb-4 relative z-10">
                        {winner === 'Ничья' ? '⚖️' : winner === 'Игрок' ? '🏆' : '💀'}
                        </div>
                        <h2 className={`text-3xl font-black mb-2 tracking-widest uppercase relative z-10 font-serif ${winner === 'Игрок' ? 'text-amber-400' : winner === 'Бот' ? 'text-rose-400' : 'text-stone-300'}`}>
                        {winner === 'Ничья' ? 'Ничья' : winner === 'Игрок' ? 'Победа' : 'Поражение'}
                        </h2>
                        <p className="text-stone-400 mb-8 text-lg font-serif relative z-10">
                        Счет: <span className="font-bold text-amber-100">{scores.player}</span> <span className="mx-2">—</span> <span className="font-bold text-rose-100">{scores.opponent}</span>
                        </p>
                        <button 
                        onClick={startGame}
                        className="w-full bg-gradient-to-b from-stone-700 to-stone-800 hover:from-stone-600 hover:to-stone-700 active:from-stone-800 active:to-stone-900 text-stone-200 font-bold py-4 rounded-xl transition-all text-lg border border-stone-600/50 uppercase tracking-widest relative z-10"
                        >
                        Сыграть еще
                        </button>
                    </div>
                    </div>
                )}
                </div>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>

```
